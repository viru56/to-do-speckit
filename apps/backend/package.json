    "db:reset": "prisma migrate reset"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^9.0.0",
    "@prisma/client": "^5.22.0",
    "@todo-app/types": "workspace:*",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.3.1",
    "fastify": "^5.1.0",
    "fastify-plugin": "^4.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.4.5",
    "vitest": "^2.1.8"
  }
}
